{
  "name": "metakb",
  "private": true,
  "scripts": {
    "dev": "turbo run dev --parallel",
    "prepare": "husky",
    "lint-staged": "lint-staged --fail-on-changes --continue-on-error --no-revert",
    "format": "pnpm --filter client format && ruff check server --fix && ruff format server"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "json-schema-to-typescript": "^15.0.4",
    "lint-staged": "^16.2.7",
    "turbo": "^1.13.4"
  },
  "lint-staged": {
    "server/**/*.py": [
      "ruff format",
      "ruff check --fix --exit-non-zero-on-fix"
    ],
    "*": [
      "prek run --skip ruff-check --skip ruff-format --files"
    ]
  },
  "dependencies": {
    "@mui/x-data-grid": "^8.21.0"
  }
}
