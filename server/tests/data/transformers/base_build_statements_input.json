  "civic.eid:1420": {
    "id": "civic.eid:1420",
    "type": "Statement",
    "description": "Study examined rare SNPs on MAP2K7 among a discovery and two validation cohorts. It was discovered that the E116K genotype was associated with a reduced median survival time of 4 and 7 months for E/K or K/K genotypes (P=2.61E-7) and an increased cancer death risk for heterozygous (HR=1.49) and homozygous (HR=1.94) genotypes for a pooled cohort. Further nude mice harboring this variant showed increased xenograft growth and metastasis.",
    "specifiedBy": {
      "id": "civic.method:2019",
      "type": "Method",
      "name": "CIViC Curation SOP (2019)",
      "methodType": "curation",
      "reportedIn": {
        "id": "pmid:31779674",
        "type": "Document",
        "name": "Danos et al., 2019, Genome Med.",
        "aliases": ["CIViC curation SOP"],
